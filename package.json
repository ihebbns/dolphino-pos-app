{
  "name": "dolphino-pos",
  "version": "1.1.0",
  "description": "Système de caisse POS — Multi-client (Servio OS)",
  "main": "core/main.js",
  "author": "Servio OS",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "start:dolphino": "set CLIENT_DIR=clients/dolphino&& electron .",
    "start:mio_food": "set CLIENT_DIR=clients/mio_food&& electron .",
    "build:win": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "tn.dolphino.pos",
    "productName": "Dolphino POS",
    "copyright": "© 2025 Servio OS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "core/main.js",
      "core/database.js",
      "core/preload.js",
      "index.html",
      "node_modules/sql.js/dist/**"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/**"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dolphino POS",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "DolphinoPOS-portable.exe"
    }
  }
}
